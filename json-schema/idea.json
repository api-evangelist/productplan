{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/productplan/main/json-schema/idea.json",
  "title": "Idea",
  "description": "A product idea captured in the ProductPlan Discovery module.",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique identifier for the idea"
    },
    "title": {
      "type": "string",
      "description": "Title of the idea"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the idea"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags associated with the idea"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "title"]
}
